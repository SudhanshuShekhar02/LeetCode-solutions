class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
         priority_queue<int> maxHeap;
        int n=nums.size();
        for(int i = 0; i < n; i++){
            maxHeap.push(nums[i]);
        }
        for(int i=0;i<k-1;i++){
            maxHeap.pop();
        }
        return maxHeap.top();
    }
};
        
